@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation

<div class="app-shell @(collapsed ? "is-collapsed" : string.Empty)">
    <aside class="@($"sidebar active-{activeNav}")" aria-label="Primary navigation">
        <span class="sidebar-indicator" aria-hidden="true"></span>
        <div class="sidebar-top">
            <a class="brand" href="/" aria-label="Billing Management">
                <span class="brand-mark">BM</span>
                <span class="sidebar-text">Billing Management</span>
            </a>

            <button class="sidebar-toggle" type="button" @onclick="Toggle" aria-label="Toggle sidebar" aria-expanded="@(!collapsed)">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M14.7 6.7a1 1 0 0 1 0 1.4L10.8 12l3.9 3.9a1 1 0 1 1-1.4 1.4l-4.6-4.6a1 1 0 0 1 0-1.4l4.6-4.6a1 1 0 0 1 1.4 0Z" />
                </svg>
            </button>
        </div>

        <nav class="nav-list" aria-label="Primary">
            <a class="@NavClass(NavCustomers)" href="/customers" title="Customers" aria-current="@AriaCurrent(NavCustomers)" @onclick="() => SetActive(NavCustomers)">
                <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                        <path d="M16 11c1.66 0 3-1.57 3-3.5S17.66 4 16 4s-3 1.57-3 3.5S14.34 11 16 11Zm-8 0c1.66 0 3-1.57 3-3.5S9.66 4 8 4 5 5.57 5 7.5 6.34 11 8 11Zm0 2c-2.67 0-6 1.34-6 4v1.5c0 .83.67 1.5 1.5 1.5h9c.83 0 1.5-.67 1.5-1.5V17c0-2.66-3.33-4-6-4Zm8 0c-.32 0-.66.02-1 .06 1.16.84 2 2.02 2 3.94v1.5c0 .53-.14 1.04-.38 1.5h3.88c.83 0 1.5-.67 1.5-1.5V17c0-2.66-3.33-4-6-4Z" />
                    </svg>
                </span>
                <span class="sidebar-text">Customers</span>
            </a>
            <a class="@NavClass(NavQuotations)" href="#quotations" title="Quotations" aria-current="@AriaCurrent(NavQuotations)" @onclick="() => SetActive(NavQuotations)">
                <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                        <path d="M6 2h9l5 5v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Zm8 1.8V8h4.2L14 3.8ZM8 11a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2H8Zm0 4a1 1 0 1 0 0 2h5a1 1 0 1 0 0-2H8Z" />
                    </svg>
                </span>
                <span class="sidebar-text">Quotations</span>
            </a>
            <a class="@NavClass(NavInvoices)" href="#invoices" title="Invoices" aria-current="@AriaCurrent(NavInvoices)" @onclick="() => SetActive(NavInvoices)">
                <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                        <path d="M7 2h10a2 2 0 0 1 2 2v18l-3-2-2 2-2-2-2 2-2-2-3 2V4a2 2 0 0 1 2-2Zm2 6a1 1 0 0 0 0 2h6a1 1 0 1 0 0-2H9Zm0 4a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2H9Zm0 4a1 1 0 1 0 0 2h3a1 1 0 1 0 0-2H9Z" />
                    </svg>
                </span>
                <span class="sidebar-text">Invoices</span>
            </a>
        </nav>

        <a class="@CompanyClass" href="/company-profile" title="Company profile" aria-current="@AriaCurrent(NavCompany)" @onclick="() => SetActive(NavCompany)">
            <span class="company-avatar" aria-hidden="true">BM</span>
            <span class="company-copy sidebar-text">
                <span>Company profile</span>
                <small>Owner settings</small>
            </span>
        </a>
    </aside>

    <main class="content-shell">
        @Body
    </main>
</div>

@code {
    private const string NavCustomers = "customers";
    private const string NavQuotations = "quotations";
    private const string NavInvoices = "invoices";
    private const string NavCompany = "company";

    private bool collapsed;
    private string activeNav = NavCustomers;

    protected override void OnInitialized()
    {
        activeNav = GetActiveNav(Navigation.Uri);
        Navigation.LocationChanged += OnLocationChanged;
    }

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;

    private void Toggle() => collapsed = !collapsed;

    private void SetActive(string item) => activeNav = item;

    private string NavClass(string item) => activeNav == item ? "nav-item active" : "nav-item";

    private string CompanyClass => activeNav == NavCompany ? "company-link active" : "company-link";

    private string? AriaCurrent(string item) => activeNav == item ? "page" : null;

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs args)
    {
        activeNav = GetActiveNav(args.Location);
        _ = InvokeAsync(StateHasChanged);
    }

    private string GetActiveNav(string uri)
    {
        var relative = Navigation.ToBaseRelativePath(uri);
        var hashIndex = relative.IndexOf('#');
        var path = (hashIndex >= 0 ? relative[..hashIndex] : relative).TrimEnd('/');
        var hash = hashIndex >= 0 ? relative[(hashIndex + 1)..] : string.Empty;

        if (path.Equals("company-profile", StringComparison.OrdinalIgnoreCase))
        {
            return NavCompany;
        }

        return hash switch
        {
            NavQuotations => NavQuotations,
            NavInvoices => NavInvoices,
            _ => NavCustomers
        };
    }
}
