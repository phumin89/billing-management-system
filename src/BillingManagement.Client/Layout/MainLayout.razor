@inherits LayoutComponentBase

<div class="app-shell @(collapsed ? "is-collapsed" : string.Empty)">
    <aside class="sidebar" aria-label="Primary navigation">
        <div class="sidebar-top">
            <a class="brand" href="/" aria-label="Billing Management">
                <span class="brand-mark">BM</span>
                <span class="sidebar-text">Billing Management</span>
            </a>

            <button class="sidebar-toggle" type="button" @onclick="Toggle" aria-label="Toggle sidebar" aria-expanded="@(!collapsed)">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M14.7 6.7a1 1 0 0 1 0 1.4L10.8 12l3.9 3.9a1 1 0 1 1-1.4 1.4l-4.6-4.6a1 1 0 0 1 0-1.4l4.6-4.6a1 1 0 0 1 1.4 0Z" />
                </svg>
            </button>
        </div>

        <nav class="nav-list" aria-label="Primary">
            <a class="nav-item active" href="#customers" title="Customers" aria-current="page">
                <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                        <path d="M16 11c1.66 0 3-1.57 3-3.5S17.66 4 16 4s-3 1.57-3 3.5S14.34 11 16 11Zm-8 0c1.66 0 3-1.57 3-3.5S9.66 4 8 4 5 5.57 5 7.5 6.34 11 8 11Zm0 2c-2.67 0-6 1.34-6 4v1.5c0 .83.67 1.5 1.5 1.5h9c.83 0 1.5-.67 1.5-1.5V17c0-2.66-3.33-4-6-4Zm8 0c-.32 0-.66.02-1 .06 1.16.84 2 2.02 2 3.94v1.5c0 .53-.14 1.04-.38 1.5h3.88c.83 0 1.5-.67 1.5-1.5V17c0-2.66-3.33-4-6-4Z" />
                    </svg>
                </span>
                <span class="sidebar-text">Customers</span>
            </a>
            <a class="nav-item" href="#quotations" title="Quotations">
                <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                        <path d="M6 2h9l5 5v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Zm8 1.8V8h4.2L14 3.8ZM8 11a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2H8Zm0 4a1 1 0 1 0 0 2h5a1 1 0 1 0 0-2H8Z" />
                    </svg>
                </span>
                <span class="sidebar-text">Quotations</span>
            </a>
            <a class="nav-item" href="#invoices" title="Invoices">
                <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                        <path d="M7 2h10a2 2 0 0 1 2 2v18l-3-2-2 2-2-2-2 2-2-2-3 2V4a2 2 0 0 1 2-2Zm2 6a1 1 0 0 0 0 2h6a1 1 0 1 0 0-2H9Zm0 4a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2H9Zm0 4a1 1 0 1 0 0 2h3a1 1 0 1 0 0-2H9Z" />
                    </svg>
                </span>
                <span class="sidebar-text">Invoices</span>
            </a>
        </nav>

        <a class="company-link" href="/company-profile" title="Company profile">
            <span class="company-avatar" aria-hidden="true">BM</span>
            <span class="company-copy sidebar-text">
                <span>Company profile</span>
                <small>Owner settings</small>
            </span>
        </a>
    </aside>

    <main class="content-shell">
        @Body
    </main>
</div>

@code {
    private bool collapsed;

    private void Toggle() => collapsed = !collapsed;
}
