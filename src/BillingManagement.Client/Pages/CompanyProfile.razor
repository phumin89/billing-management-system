@page "/company-profile"
@using BillingManagement.Client.OwnerCompanyProfiles
@using BillingManagement.Contracts.OwnerCompanyProfiles
@inject OwnerCompanyProfileClient Client

<PageTitle>Company profile</PageTitle>

<main class="page-shell">
    <header class="page-header">
        <div>
            <h1>Company profile</h1>
            <p>This information appears on quotation and invoice headers.</p>
        </div>
    </header>

    @if (isLoading)
    {
        <p>Loading company profile...</p>
    }
    else if (profile is not null)
    {
        <section class="panel">
            <div class="success-banner">Company profile saved.</div>
            <dl class="profile-list">
                <dt>Company name</dt>
                <dd>@profile.CompanyName</dd>
                <dt>Address</dt>
                <dd>@profile.AddressLine1 @profile.AddressLine2, @profile.City @profile.PostalCode, @profile.Country</dd>
                <dt>Tax ID</dt>
                <dd>@Display(profile.TaxId)</dd>
                <dt>Phone</dt>
                <dd>@Display(profile.Phone)</dd>
                <dt>Email</dt>
                <dd>@Display(profile.Email)</dd>
                <dt>Website</dt>
                <dd>@Display(profile.Website)</dd>
                <dt>Logo reference</dt>
                <dd>@Display(profile.LogoReference)</dd>
                <dt>Registration number</dt>
                <dd>@Display(profile.RegistrationNumber)</dd>
            </dl>
        </section>
    }
    else if (!showForm)
    {
        <section class="panel empty-state">
            <p>Add your company details so quotations and invoices show the correct seller information.</p>
            <button class="primary-button" type="button" @onclick="() => showForm = true">Create company profile</button>
        </section>
    }
    else
    {
        <EditForm Model="request" OnValidSubmit="Save">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="error-banner">@errorMessage</div>
            }

            <ValidationSummary />

            <section class="form-section">
                <h2>Company identity</h2>
                <label>
                    Company name
                    <InputText @bind-Value="request.CompanyName" />
                    <ValidationMessage For="() => request.CompanyName" />
                    @FieldError(nameof(request.CompanyName))
                </label>
                <label>
                    Tax ID
                    <InputText @bind-Value="request.TaxId" />
                </label>
                <label>
                    Registration number / business reference
                    <InputText @bind-Value="request.RegistrationNumber" />
                </label>
            </section>

            <section class="form-section">
                <h2>Address</h2>
                <label>
                    Address line 1
                    <InputText @bind-Value="request.AddressLine1" />
                    <ValidationMessage For="() => request.AddressLine1" />
                    @FieldError(nameof(request.AddressLine1))
                </label>
                <label>
                    Address line 2
                    <InputText @bind-Value="request.AddressLine2" />
                </label>
                <label>
                    City / province / state
                    <InputText @bind-Value="request.City" />
                    <ValidationMessage For="() => request.City" />
                    @FieldError(nameof(request.City))
                </label>
                <label>
                    Postal code
                    <InputText @bind-Value="request.PostalCode" />
                    <ValidationMessage For="() => request.PostalCode" />
                    @FieldError(nameof(request.PostalCode))
                </label>
                <label>
                    Country
                    <InputText @bind-Value="request.Country" />
                    <ValidationMessage For="() => request.Country" />
                    @FieldError(nameof(request.Country))
                </label>
            </section>

            <section class="form-section">
                <h2>Contact</h2>
                <label>
                    Phone
                    <InputText @bind-Value="request.Phone" />
                </label>
                <label>
                    Email
                    <InputText @bind-Value="request.Email" />
                    <ValidationMessage For="() => request.Email" />
                    @FieldError(nameof(request.Email))
                </label>
                <label>
                    Website
                    <InputText @bind-Value="request.Website" />
                </label>
            </section>

            <section class="form-section">
                <h2>Document assets/references</h2>
                <label>
                    Logo reference/upload placeholder
                    <InputText @bind-Value="request.LogoReference" />
                </label>
            </section>

            <div class="form-actions">
                <button class="primary-button" type="submit" disabled="@isSaving">
                    @(isSaving ? "Saving..." : "Save company profile")
                </button>
            </div>
        </EditForm>
    }
</main>

@code {
    private readonly CreateOwnerCompanyProfileRequest request = new();
    private OwnerCompanyProfileResponse? profile;
    private IReadOnlyDictionary<string, string[]> apiErrors = new Dictionary<string, string[]>();
    private bool isLoading = true;
    private bool isSaving;
    private bool showForm;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        profile = await Client.Get();
        isLoading = false;
    }

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        apiErrors = new Dictionary<string, string[]>();

        try
        {
            var result = await Client.Create(request);
            if (result.Succeeded)
            {
                profile = result.Profile;
                showForm = false;
            }
            else
            {
                apiErrors = result.Errors;
                errorMessage = "Fix the highlighted fields and try again.";
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "Company profile could not be saved. Try again.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private RenderFragment FieldError(string fieldName) => builder =>
    {
        if (!apiErrors.TryGetValue(fieldName, out var messages))
        {
            return;
        }

        foreach (var message in messages)
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "validation-message");
            builder.AddContent(2, message);
            builder.CloseElement();
        }
    };

    private static string Display(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "Not provided" : value;
}
