@page "/company-profile"
<PageTitle>Company profile</PageTitle>

<main class="company-profile-page">
    <header class="company-page-header">
        <div>
            <p class="company-page-kicker">Owner company</p>
            <h1>Company profile</h1>
            <p>Seller information used later on quotation and invoice document headers.</p>
        </div>
    </header>

    @if (isLoading)
    {
        <section class="company-card company-empty-card">
            <div>
                <h2>Loading company profile</h2>
                <p>Checking saved seller information.</p>
            </div>
        </section>
    }
    else if (reviewState == ProfileReviewState.Empty)
    {
        <section class="company-card company-empty-card" data-profile-view="empty">
            <div>
                <h2>No company profile yet</h2>
                <p>Add company details so document headers show the correct seller information.</p>
            </div>
            <button class="company-primary-button" type="button" @onclick="ShowCreate">Create company profile</button>
        </section>
    }
    else if (reviewState == ProfileReviewState.Existing)
    {
        <section class="company-card" data-profile-view="existing">
            <div class="company-card-header">
                <div>
                    <h2>@DisplayProfile.CompanyName</h2>
                    <p>Primary owner company profile.</p>
                </div>
                <div class="company-actions">
                    <button class="company-secondary-button" type="button" @onclick="ShowEdit">Update</button>
                    <button class="company-danger-button" type="button" @onclick="ShowDelete">Delete</button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <p class="company-status-message" role="alert">@statusMessage</p>
            }

            <dl class="company-summary-grid">
                <div class="full">
                    <dt>Address</dt>
                    <dd>@DisplayProfile.AddressLine1, @DisplayProfile.AddressLine2, @DisplayProfile.CityProvinceState, @DisplayProfile.PostalCode, @DisplayProfile.Country</dd>
                </div>
                <div>
                    <dt>Tax ID</dt>
                    <dd>@DisplayProfile.TaxId</dd>
                </div>
                <div>
                    <dt>Phone</dt>
                    <dd>@DisplayProfile.Phone</dd>
                </div>
                <div>
                    <dt>Email</dt>
                    <dd>@DisplayProfile.Email</dd>
                </div>
                <div>
                    <dt>Website</dt>
                    <dd>@DisplayProfile.Website</dd>
                </div>
                <div class="full">
                    <dt>Logo/reference</dt>
                    <dd>@DisplayProfile.LogoReference</dd>
                </div>
                <div class="full">
                    <dt>Registration/business reference</dt>
                    <dd>@DisplayProfile.RegistrationNumber</dd>
                </div>
            </dl>
        </section>
    }
    else
    {
        <section class="company-card" data-profile-view="form">
            <div class="company-card-header">
                <div>
                    <h2>@(isEditMode ? "Update company profile" : "Create company profile")</h2>
                    <p>Fields marked with * are required.</p>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <p role="alert">@statusMessage</p>
            }

            <form class="company-form" @onsubmit="SaveProfile" @onsubmit:preventDefault>
                <div class="company-form-grid">
                    <div class="company-field full">
                        <label for="company-name">Company name*</label>
                        <input id="company-name" name="company-name" @bind="form.CompanyName" @bind:event="oninput" placeholder="Acme Co., Ltd." />
                        <span>@FieldError(nameof(form.CompanyName))</span>
                    </div>
                    <div class="company-field full">
                        <label for="address-line-1">Address line 1*</label>
                        <input id="address-line-1" name="address-line-1" @bind="form.AddressLine1" @bind:event="oninput" placeholder="Street address" />
                        <span>@FieldError(nameof(form.AddressLine1))</span>
                    </div>
                    <div class="company-field full">
                        <label for="address-line-2">Address line 2</label>
                        <input id="address-line-2" name="address-line-2" @bind="form.AddressLine2" @bind:event="oninput" placeholder="Suite, floor, building" />
                    </div>
                    <div class="company-field">
                        <label for="city">City / province / state*</label>
                        <input id="city" name="city" @bind="form.CityProvinceState" @bind:event="oninput" placeholder="Bangkok" />
                        <span>@FieldError(nameof(form.CityProvinceState))</span>
                    </div>
                    <div class="company-field">
                        <label for="postal-code">Postal code*</label>
                        <input id="postal-code" name="postal-code" @bind="form.PostalCode" @bind:event="oninput" placeholder="10110" />
                        <span>@FieldError(nameof(form.PostalCode))</span>
                    </div>
                    <div class="company-field">
                        <label for="country">Country*</label>
                        <input id="country" name="country" @bind="form.Country" @bind:event="oninput" placeholder="Thailand" />
                        <span>@FieldError(nameof(form.Country))</span>
                    </div>
                    <div class="company-field">
                        <label for="tax-id">Tax ID</label>
                        <input id="tax-id" name="tax-id" @bind="form.TaxId" @bind:event="oninput" placeholder="0105558123456" />
                    </div>
                    <div class="company-field">
                        <label for="phone">Phone</label>
                        <input id="phone" name="phone" @bind="form.Phone" @bind:event="oninput" placeholder="+66 2 555 0100" />
                    </div>
                    <div class="company-field">
                        <label for="email">Email</label>
                        <input id="email" name="email" @bind="form.Email" @bind:event="oninput" placeholder="billing@example.com" />
                        <span>@FieldError(nameof(form.Email))</span>
                    </div>
                    <div class="company-field">
                        <label for="website">Website</label>
                        <input id="website" name="website" @bind="form.Website" @bind:event="oninput" placeholder="https://example.com" />
                    </div>
                    <div class="company-field full">
                        <label for="logo-reference">Logo/reference placeholder</label>
                        <input id="logo-reference" name="logo-reference" @bind="form.LogoReference" @bind:event="oninput" placeholder="Logo file name or asset reference" />
                    </div>
                    <div class="company-field full">
                        <label for="registration-reference">Registration/business reference</label>
                        <input id="registration-reference" name="registration-reference" @bind="form.RegistrationNumber" @bind:event="oninput" placeholder="Business registration reference" />
                    </div>
                </div>

                <div class="company-form-actions">
                    <button class="company-secondary-button" type="button" disabled="@isSubmitting" @onclick="ShowExisting">Cancel</button>
                    <button class="company-primary-button" type="submit" disabled="@isSubmitting">
                        @(isSubmitting ? "Saving..." : isEditMode ? "Update company profile" : "Create company profile")
                    </button>
                </div>
            </form>
        </section>
    }

    @if (showDeleteSnackbar)
    {
        <div class="@SnackbarClass" role="status" data-profile-view="delete">
            <p>Delete company profile? You can create a new one later. Delete is blocked when quotations or invoices use this profile.</p>
            <div class="company-snackbar-actions">
                <button type="button" @onclick="CloseDeleteSnackbar">Cancel</button>
                <button type="button" class="danger" disabled="@isDeleting" @onclick="ConfirmDelete">Delete</button>
            </div>
        </div>
    }
</main>
